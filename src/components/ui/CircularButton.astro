---
// src/components/ui/CircularButton.astro

// Мы будем принимать ссылку и текст, который появится при наведении
export interface Props {
  href: string;
  hoverText: string;
}

const { href, hoverText } = Astro.props;
---
<!-- Весь блок - это одна большая ссылка -->
<a href={href} class="circular-button">
  <!-- Это будет фон - картинка домика, чтобы было понятно, о чем речь -->
  <div class="button-bg-image"></div>
  <!-- Это тень, как в вашем примере -->
  <div class="button-shadow"></div>
  <!-- А это оверлей, который появляется при наведении -->
  <div class="hover-overlay">
    <p>{hoverText}</p>
    <hr/>
  </div>
</a>

<style>
.circular-button {
  position: relative;
  display: block; /* Важно, чтобы размеры работали */
  width: 220px;   /* Сделаем кнопку чуть меньше, чтобы она не была громоздкой */
  height: 220px;
  border-radius: 50%;
  border: 10px solid #fff;
  background-image: linear-gradient(to top, #cccccc, #dddddd);
  box-shadow: 0 10px 30px rgba(0,0,0,0.3), 0px 1px 0px 1px rgba(250, 250, 250, 0.5) inset;
  transition: transform 0.3s ease;
}
.circular-button:hover {
  transform: scale(1.05); /* Легкое увеличение всего круга при наведении */
}

/* Фон с картинкой домика */
.button-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background-image: url('/images/renders/aboutBarn.jpeg'); /* Используем наш рендер */
  background-size: cover;
  background-position: center;
  z-index: 1;
}

/* Тень */
.button-shadow {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-shadow: 0 0 20px rgba(0, 0, 0, .6) inset;
  z-index: 2;
}

/* Оверлей, который появляется */
.hover-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background-color: var(--color-primary); /* Используем наш фирменный цвет! */
  border-radius: 50%;
  opacity: 0;
  z-index: 3;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  transition: all 0.5s ease-in-out;
  transform: translate(-50%, -50%) rotate(0deg); /* Начальное состояние */
}

/* Магия при наведении на весь круг */
.circular-button:hover .hover-overlay {
  width: 100%;
  height: 100%;
  opacity: 0.95;
  transform: translate(-50%, -50%) rotate(360deg); /* Анимация вращения */
}

.hover-overlay p {
  color: white;
  font-size: 1.2rem;
  font-weight: bold;
  opacity: 0;
  transition: opacity 0.5s ease 0.3s;
}

.hover-overlay hr {
  height: 2px;
  width: 0px;
  background: white;
  border: none;
  transition: width 0.5s ease 0.3s;
}

.circular-button:hover .hover-overlay p,
.circular-button:hover .hover-overlay hr {
  opacity: 1;
  width: 80%; /* Для линии */
}
</style>