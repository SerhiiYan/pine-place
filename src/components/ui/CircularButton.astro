---
// src/components/ui/CircularButton.astro
export interface Props {
  href: string;
  hoverText: string;
}
const { href, hoverText } = Astro.props;
---
<a href={href} class="circular-button">
  <div class="button-bg-image"></div>
  <div class="button-shadow"></div>
  <div class="hover-overlay">
    <p>{hoverText}</p>
    <hr/>
  </div>
</a>

<style>
.circular-button {
  position: relative;
  display: block;
  width: 220px;
  height: 220px;
  border-radius: 50%;
  border: 10px solid #fff;
  background-image: linear-gradient(to top, #cccccc, #dddddd);
  box-shadow: 0 10px 30px rgba(0,0,0,0.3), 0px 1px 0px 1px rgba(250, 250, 250, 0.5) inset;
  transition: transform 0.3s ease;
}
.circular-button:hover {
  transform: scale(1.05);
}
.button-bg-image {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 50%;
  background-image: url('/images/renders/aboutBarn.jpeg');
  background-size: cover;
  background-position: center;
  z-index: 1;
}
.button-shadow {
  position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 50%;
  box-shadow: 0 0 20px rgba(0, 0, 0, .6) inset;
  z-index: 2;
}
.hover-overlay {
  position: absolute; top: 50%; left: 50%; width: 0; height: 0;
  background-color: var(--color-primary);
  border-radius: 50%;
  opacity: 0;
  z-index: 3;
  overflow: hidden;
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  transition: all 0.5s ease-in-out;
  transform: translate(-50%, -50%) rotate(0deg);
}
.circular-button:hover .hover-overlay {
  width: 100%; height: 100%; opacity: 0.95;
  transform: translate(-50%, -50%) rotate(360deg);
}
.hover-overlay p {
  color: white; font-size: 1.2rem; font-weight: bold; opacity: 0;
  transition: opacity 0.5s ease 0.3s;
}
.hover-overlay hr {
  height: 2px; width: 0px; background: white; border: none;
  transition: width 0.5s ease 0.3s;
}
.circular-button:hover .hover-overlay p,
.circular-button:hover .hover-overlay hr {
  opacity: 1;
  width: 80%;
}
</style>