---
// src/components/sections/HeroSection.astro
import CircularButton from '../ui/CircularButton.astro'; 
---
<section class="hero-section">
  
  <div class="video-background">
    <video autoplay loop muted playsinline src="/video/hero-video.mp4"></video>
  </div>
  
  <div class="container"> 
    <div class="hero-content">
      <h1>Pine & Place</h1>
      <p class="descriptor">Место твоей тишины</p>
      <CircularButton 
        href="#details" 
        hoverText="Посмотреть домик" 
      />
    </div>
  </div>

</section>

<style>
  .hero-section {
    position: relative; 
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden; 
    color: white;
  }

  /* 
    Теперь это не просто контейнер, а сцена для наших слоев.
  */
  .video-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  /* 
    Слой 1: ВИДЕО. На самом нижнем уровне.
  */
  .video-background video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover; 
    z-index: 1; /* Самый нижний слой */
  }

  /* 
    Слой 2: ЗАТЕМНЕНИЕ. Поверх видео.
  */
  .video-background::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    z-index: 2; /* Слой над видео */
  }

  /*
    Слой 3: КОНТЕНТ. Поверх всего остального.
  */
  .hero-content {
    position: relative;
    z-index: 3; /* Самый верхний слой */
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  
  .hero-content h1 {
    font-size: 4rem; 
    margin: 0;
    text-shadow: 0px 2px 8px rgba(0, 0, 0, 0.5); 
  }
  
  .descriptor {
    font-size: 1.5rem;
    margin-top: 10px;
    text-shadow: 0px 2px 8px rgba(0, 0, 0, 0.5);
    margin-bottom: 40px; 
  }
</style>